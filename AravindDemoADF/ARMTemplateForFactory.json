									"treatBooleanAsNumber": false
								}
							}
						},
						"inputs": [
							{
								"referenceName": "AzureSqlTable1",
								"type": "DatasetReference",
								"parameters": {}
							}
						],
						"outputs": [
							{
								"referenceName": "Dynamicparquet",
								"type": "DatasetReference",
								"parameters": {
									"container": "bronzecontainer",
									"folder": "users",
									"file": {
										"value": "@concat(pipeline().parameters.Table,'_',variables('CurrentTimeStamp'))",
										"type": "Expression"
									}
								}
							}
						]
					},
					{
						"name": "Last_CDC",
						"type": "Lookup",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "JsonSource",
								"storeSettings": {
									"type": "AzureBlobFSReadSettings",
									"recursive": true,
									"enablePartitionDiscovery": false
								},
								"formatSettings": {
									"type": "JsonReadSettings"
								}
							},
							"dataset": {
								"referenceName": "Spotify",
								"type": "DatasetReference",
								"parameters": {
									"container": "bronzecontainer",
									"folder": "CDC",
									"file": "cdc.json"
								}
							},
							"firstRowOnly": false
						}
					},
